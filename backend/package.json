    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.1.2",
    "jsonwebtoken": "^9.0.3",
    "mailgun-js": "^0.22.0",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "winston": "^3.3.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.10.5",
